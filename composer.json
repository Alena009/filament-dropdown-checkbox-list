{
  "name": "alenadashko/filament-dropdown-checkbox-list",
  "description": "A searchable dropdown CheckboxList component for Filament v3",
  "keywords": ["filament", "laravel", "checkbox", "dropdown", "form", "component"],
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Alena Dashko",
      "email": "your@email.com"
    }
  ],
  "require": {
    "php": "^8.1",
    "filament/filament": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "AlenaDashko\\DropdownCheckboxList\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "AlenaDashko\\DropdownCheckboxList\\DropdownCheckboxListServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}